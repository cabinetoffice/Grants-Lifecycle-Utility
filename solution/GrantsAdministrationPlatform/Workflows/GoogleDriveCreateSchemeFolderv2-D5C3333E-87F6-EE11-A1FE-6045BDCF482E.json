              "metadata": {
                "operationMetadataId": "bf7b96e1-cd14-4ac4-81d2-963c70873b13"
              },
              "type": "Compose",
              "inputs": "Scheme: @{replace(\r\n  replace(\r\n    replace(\r\n      replace(\r\n        replace(\r\n          replace(\r\n            replace(\r\n              replace(\r\n                replace(\r\n                  replace(\r\n                    triggerBody()?['gap_title'],\r\n                    '/', '|'\r\n                  ),\r\n                  '\\', '|'\r\n                ),\r\n                ':', '-'\r\n              ),\r\n              '*', ' '\r\n            ),\r\n            '?', ' '\r\n          ),\r\n          '\"', ' '\r\n        ),\r\n        '<', '-'\r\n      ),\r\n      '>', '-'\r\n    ),\r\n    '#', ''\r\n  ),\r\n  '%', '_'\r\n)}"
            },
            "Get_File": {
              "runAfter": {
                "Name": [
